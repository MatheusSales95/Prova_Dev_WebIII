{
  "name": "sistema-reservas-mesa",
  "version": "1.0.0",
  "description": "Sistema de Reservas de Mesa para restaurante - Prova 2 Desenvolvimento Web III (TypeScript + Express + MongoDB)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
